# Database
DATABASE_URL="postgresql://user:password@localhost:5432/agroportal"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudflare R2
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="agroportal"
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# Redis
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# Resend (email)
RESEND_API_KEY="re_your-key"
RESEND_FROM_EMAIL="noreply@agroportal.pl"

# PayU
PAYU_POS_ID="your-pos-id"
PAYU_MD5_KEY="your-md5-key"
PAYU_OAUTH_CLIENT_ID="your-client-id"
PAYU_OAUTH_CLIENT_SECRET="your-client-secret"
